# Dockerfile.test.dockerignore
# Used automatically by Docker when building with: -f Dockerfile.test
# Overrides the default .dockerignore for the test image build.
# Unlike production, we INCLUDE:
#   - data/bird_mini_dev.sqlite  (baked into the test image)
#   - seed_test_user.py          (run at build time to seed tester account)

# ── Git ───────────────────────────────────────────────────
.git/
.github/
.gitignore
.gitattributes

# ── Environment ───────────────────────────────────────────
.env
.env.*.local
.env.local
# .env.test is also excluded — image must not bake in any API key
.env.test

# ── Python ────────────────────────────────────────────────
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
.pytest_cache/
.tox/
dist/
build/

# ── IDE / editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# ── Docker meta (not needed inside the image) ─────────────
Dockerfile
Dockerfile.test
docker-compose.yml
docker-compose.test.yml
.dockerignore

# ── Development & evaluation scripts ─────────────────────
test_req.py
evaluate.py
metrics_calculator.py
README.md
TESTERS_README.md
*.test.js
*.test.py

# ── Runtime-only data: include sqlite, exclude chroma_db ──
# data/bird_mini_dev.sqlite  → INCLUDED (baked in)
# data/users.sqlite          → excluded; seed_test_user.py creates it at build time
data/users.sqlite

# ── KG: keep vector store, exclude build scripts ──────────
# kg/build_vlkg.py  → excluded (offline-only VLKG construction script)
# kg/update_vlkg.py → INCLUDED: needed at runtime by APScheduler delta_update job
kg/build_vlkg.py

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── Node ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS ────────────────────────────────────────────────────
Thumbs.db

# ── Docs ──────────────────────────────────────────────────
docs/
examples/
.editorconfig
.pre-commit-config.yaml

# ── Sessions output (never bake into image) ───────────────
sessions/
